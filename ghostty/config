font-family = JetBrains Mono
font-size = 9.75
# adjust-cell-height = -2.5%
# adjust-cell-width= -2.5%

# theme = dark: darktheme,light: Adwaita Dark
# theme = dark: Adwaita Dark,light: Adwaita
# theme = JetBrains Darcula
theme = darktheme
# theme = sora
# gtk-toolbar-style = flat
# background = #131517
background = #141618
# background = #0e0f13
# background = #242428
# background = #242428
# background = #232627

# command = zellij -l welcome

window-theme = ghostty
# window-show-tab-bar = auto
gtk-titlebar = false
gtk-titlebar-style = tabs
gtk-titlebar-hide-when-maximized = true
unfocused-split-opacity = 1
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
mouse-hide-while-typing = true

# window-height = 51
# window-width = 192
# window-height = 38
# window-width = 121

keybind = ctrl+shift+]=next_tab
keybind = ctrl+shift+[=previous_tab
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right
keybind = ctrl+shift+j=goto_split:down
keybind = ctrl+shift+k=goto_split:up
keybind = ctrl+shift+alt+]=move_tab:1
keybind = ctrl+shift+alt+[=move_tab:-1
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8
keybind = ctrl+shift+alt+o=toggle_tab_overview
bell-features = system,border
